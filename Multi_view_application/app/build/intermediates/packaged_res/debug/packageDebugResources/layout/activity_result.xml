<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/result_screen_bg">

    <ScrollView
        android:id="@+id/resultScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/footerSection">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/main"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="40dp"
            tools:context=".ResultActivity">

           <!-- Icon to go back to the home screen -->
            <ImageView
                android:id="@+id/icon_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginTop="24dp"
                android:layout_marginStart="20dp"
                android:src="@drawable/icon_back"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvMoodTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="80dp"
                android:fontFamily="@font/risque"
                android:text="Calm Mode"
                android:textColor="#FFFFFF"
                android:textSize="32sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/risque"
                android:text="Perfumes picked for your mood"
                android:textColor="#E0D8D8"
                android:textSize="18sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tvMoodTitle" />

            <!-- Perfume box 1 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/box1"
                android:layout_width="0dp"
                android:layout_height="250dp"
                android:layout_marginTop="30dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="6dp"
                android:alpha="0"
                android:translationY="40dp"
                app:cardBackgroundColor="#4B4848"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:layout_constraintEnd_toStartOf="@+id/box2"
                app:layout_constraintHorizontal_weight="1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tvSubtitle">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <!-- Favorite icon -->
                    <ImageButton
                        android:id="@+id/fav1"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_alignParentEnd="true"
                        android:layout_marginTop="12dp"
                        android:layout_marginEnd="12dp"
                        android:padding="4dp"
                        android:scaleType="fitCenter"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/fav_icon" />

                    <!-- First perfume image -->
                    <ImageView
                        android:id="@+id/imgPerfume1"
                        android:layout_width="match_parent"
                        android:layout_height="115dp"
                        android:layout_marginTop="25dp"
                        android:src="@drawable/yulong_perfume"
                        android:scaleType="fitCenter" />

                    <!-- Perfume name -->
                    <TextView
                        android:id="@+id/name1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerHorizontal="true"
                        android:layout_below="@id/imgPerfume1"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/risque"
                        android:text="Yulong"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp" />

                    <!-- Perfume price -->
                    <TextView
                        android:id="@+id/price1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerHorizontal="true"
                        android:layout_below="@id/name1"
                        android:layout_marginTop="2dp"
                        android:text="250 AED"
                        android:textColor="#CCCCCC"
                        android:textSize="14sp" />

                   <!-- Add to cart button -->
                    <Button
                        android:id="@+id/btnCart1"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_alignParentBottom="true"
                        android:backgroundTint="#65000B"
                        android:insetBottom="0dp"
                        android:text="Add to Cart"
                        app:cornerRadius="20dp" />
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

           <!-- Perfume box 2 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/box2"
                android:layout_width="0dp"
                android:layout_height="250dp"
                android:layout_marginTop="30dp"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="24dp"
                android:alpha="0"
                android:translationY="40dp"
                app:cardBackgroundColor="#4B4848"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_weight="1"
                app:layout_constraintStart_toEndOf="@+id/box1"
                app:layout_constraintTop_toBottomOf="@+id/tvSubtitle">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageButton
                        android:id="@+id/fav2"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_alignParentEnd="true"
                        android:layout_marginTop="12dp"
                        android:layout_marginEnd="12dp"
                        android:padding="4dp"
                        android:scaleType="fitCenter"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/fav_icon" />

                    <ImageView
                        android:id="@+id/imgPerfume2"
                        android:layout_width="match_parent"
                        android:layout_height="115dp"
                        android:layout_marginTop="25dp"
                        android:src="@drawable/perfume_that"
                        android:scaleType="fitCenter" />

                    <TextView
                        android:id="@+id/name2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerHorizontal="true"
                        android:layout_below="@id/imgPerfume2"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/risque"
                        android:text="Perfume That"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/price2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerHorizontal="true"
                        android:layout_below="@id/name2"
                        android:layout_marginTop="2dp"
                        android:text="250 AED"
                        android:textColor="#CCCCCC"
                        android:textSize="14sp" />

                    <Button
                        android:id="@+id/btnCart2"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_alignParentBottom="true"
                        android:backgroundTint="#65000B"
                        android:insetBottom="0dp"
                        android:text="Add to Cart"
                        app:cornerRadius="20dp" />
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

           <!-- Perfume box 3 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card3"
                android:layout_width="0dp"
                android:layout_height="250dp"
                android:layout_marginTop="25dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="6dp"
                android:alpha="0"
                android:translationY="40dp"
                app:cardBackgroundColor="#4B4848"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:layout_constraintEnd_toStartOf="@+id/card4"
                app:layout_constraintHorizontal_weight="1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/box1">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageButton
                        android:id="@+id/fav3"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_alignParentEnd="true"
                        android:layout_marginTop="12dp"
                        android:layout_marginEnd="12dp"
                        android:padding="4dp"
                        android:scaleType="fitCenter"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/fav_icon" />

                    <ImageView
                        android:id="@+id/imgPerfume3"
                        android:layout_width="match_parent"
                        android:layout_height="115dp"
                        android:layout_marginTop="25dp"
                        android:src="@drawable/french"
                        android:scaleType="fitCenter" />

                    <TextView
                        android:id="@+id/name3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerHorizontal="true"
                        android:layout_below="@id/imgPerfume3"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/risque"
                        android:text="French"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/price3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerHorizontal="true"
                        android:layout_below="@id/name3"
                        android:layout_marginTop="2dp"
                        android:text="250 AED"
                        android:textColor="#CCCCCC"
                        android:textSize="14sp" />

                    <Button
                        android:id="@+id/btnCart3"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_alignParentBottom="true"
                        android:backgroundTint="#65000B"
                        android:insetBottom="0dp"
                        android:text="Add to Cart"
                        app:cornerRadius="20dp" />
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <!-- Perfume box 4 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card4"
                android:layout_width="0dp"
                android:layout_height="250dp"
                android:layout_marginTop="25dp"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="24dp"
                android:alpha="0"
                android:translationY="40dp"
                app:cardBackgroundColor="#4B4848"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_weight="1"
                app:layout_constraintStart_toEndOf="@+id/card3"
                app:layout_constraintTop_toBottomOf="@+id/box2">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageButton
                        android:id="@+id/fav4"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_alignParentEnd="true"
                        android:layout_marginTop="12dp"
                        android:layout_marginEnd="12dp"
                        android:padding="4dp"
                        android:scaleType="fitCenter"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/fav_icon" />

                    <ImageView
                        android:id="@+id/imgPerfume4"
                        android:layout_width="match_parent"
                        android:layout_height="115dp"
                        android:layout_marginTop="25dp"
                        android:src="@drawable/milky_musk"
                        android:scaleType="fitCenter" />

                    <TextView
                        android:id="@+id/name4"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerHorizontal="true"
                        android:layout_below="@id/imgPerfume4"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/risque"
                        android:text="Milky Musk"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/price4"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerHorizontal="true"
                        android:layout_below="@id/name4"
                        android:layout_marginTop="2dp"
                        android:text="250 AED"
                        android:textColor="#CCCCCC"
                        android:textSize="14sp" />

                    <Button
                        android:id="@+id/btnCart4"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_alignParentBottom="true"
                        android:backgroundTint="#65000B"
                        android:insetBottom="0dp"
                        android:text="Add to Cart"
                        app:cornerRadius="20dp" />
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <!-- Perfume box 5 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card5"
                android:layout_width="0dp"
                android:layout_height="250dp"
                android:layout_marginTop="25dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="6dp"
                android:alpha="0"
                android:translationY="40dp"
                app:cardBackgroundColor="#4B4848"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:layout_constraintEnd_toStartOf="@+id/card6"
                app:layout_constraintHorizontal_weight="1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/card3">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageButton
                        android:id="@+id/fav5"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_alignParentEnd="true"
                        android:layout_marginTop="12dp"
                        android:layout_marginEnd="12dp"
                        android:padding="4dp"
                        android:scaleType="fitCenter"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/fav_icon" />

                    <ImageView
                        android:id="@+id/imgPerfume5"
                        android:layout_width="match_parent"
                        android:layout_height="115dp"
                        android:layout_marginTop="25dp"
                        android:src="@drawable/givenchy"
                        android:scaleType="fitCenter" />

                    <TextView
                        android:id="@+id/name5"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerHorizontal="true"
                        android:layout_below="@id/imgPerfume5"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/risque"
                        android:text="Givenchy"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/price5"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerHorizontal="true"
                        android:layout_below="@id/name5"
                        android:layout_marginTop="2dp"
                        android:text="250 AED"
                        android:textColor="#CCCCCC"
                        android:textSize="14sp" />

                    <Button
                        android:id="@+id/btnCart5"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_alignParentBottom="true"
                        android:backgroundTint="#65000B"
                        android:insetBottom="0dp"
                        android:text="Add to Cart"
                        app:cornerRadius="20dp" />
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <!-- Perfume box 6 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card6"
                android:layout_width="0dp"
                android:layout_height="250dp"
                android:layout_marginTop="25dp"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="24dp"
                android:alpha="0"
                android:translationY="40dp"
                app:cardBackgroundColor="#4B4848"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_weight="1"
                app:layout_constraintStart_toEndOf="@+id/card5"
                app:layout_constraintTop_toBottomOf="@+id/card4">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageButton
                        android:id="@+id/fav6"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_alignParentEnd="true"
                        android:layout_marginTop="12dp"
                        android:layout_marginEnd="12dp"
                        android:padding="4dp"
                        android:scaleType="fitCenter"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/fav_icon" />

                    <ImageView
                        android:id="@+id/imgPerfume6"
                        android:layout_width="match_parent"
                        android:layout_height="115dp"
                        android:layout_marginTop="25dp"
                        android:src="@drawable/my_way"
                        android:scaleType="fitCenter" />

                    <TextView
                        android:id="@+id/name6"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerHorizontal="true"
                        android:layout_below="@id/imgPerfume6"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/risque"
                        android:text="My Way"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/price6"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerHorizontal="true"
                        android:layout_below="@id/name6"
                        android:layout_marginTop="2dp"
                        android:text="250 AED"
                        android:textColor="#CCCCCC"
                        android:textSize="14sp" />

                    <Button
                        android:id="@+id/btnCart6"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_alignParentBottom="true"
                        android:backgroundTint="#65000B"
                        android:insetBottom="0dp"
                        android:text="Add to Cart"
                        app:cornerRadius="20dp" />
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

          <!-- Footer section -->
            <View
                android:id="@+id/footer_divider"
                android:layout_width="80dp"
                android:layout_height="1.5dp"
                android:layout_marginTop="60dp"
                android:background="#FFFFFF"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/card5" />

          <!--  Quote -->
            <TextView
                android:id="@+id/tvFooterQuote"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginHorizontal="50dp"
                android:fontFamily="@font/risque"
                android:gravity="center"
                android:alpha="0.8"
                android:text="&quot;Perfume is like a piece of clothing, a message, a way of presenting oneself.&quot;"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/footer_divider" />

            <TextView
                android:id="@+id/tvFooterBranding"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:fontFamily="@font/risque"
                android:text="PERFUME BAR"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:letterSpacing="0.4"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvFooterQuote" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

<!-- Bottom navigation bar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/footerSection"
        android:layout_width="match_parent"
        android:layout_height="110dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:id="@+id/footerBg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitXY"
            android:src="@drawable/footer" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:weightSum="4"
            android:layout_marginTop="10dp">

            <LinearLayout
                android:id="@+id/btn_home"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/home_icon" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Home"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/risque" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_wishlist"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/wishlist_icon" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Wishlist"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/risque" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_cart"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true">

                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:src="@drawable/card_icon" />

                    <TextView
                        android:id="@+id/tvCartBadge"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_gravity="top|end"
                        android:layout_marginTop="-4dp"
                        android:layout_marginEnd="-4dp"
                        android:background="@drawable/badge_background"
                        android:gravity="center"
                        android:text="0"
                        android:textColor="#FFFFFF"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:visibility="gone" />

                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cart"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/risque" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_instructions"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/instructions_icon" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Guide"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/risque" />
            </LinearLayout>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>